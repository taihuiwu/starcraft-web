{
  "name": "starcraft-web",
  "version": "0.1.0",
  "description": "3D网页版星际争霸复刻 - Electron桌面版",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ server/ --ext .js",
    "lint:fix": "eslint --fix src/ server/ --ext .js",
    "format": "prettier --write 'src/**/*.{js,vue}' 'server/**/*.js'",
    "format:check": "prettier --check 'src/**/*.{js,vue}' 'server/**/*.js'",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:all": "vite build && electron-builder -wml",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js"
  },
  "build": {
    "appId": "com.starcraft.web",
    "productName": "StarCraft Web",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/",
        "to": "public/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "artifactName": "StarCraft-Web-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.png",
      "uninstallerIcon": "public/icon.png",
      "installerHeaderIcon": "public/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StarCraft Web"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.games",
      "artifactName": "StarCraft-Web-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Game",
      "artifactName": "StarCraft-Web-${version}-linux-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "vite": "^5.0.0",
    "vitest": "^1.6.1",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "three": "^0.160.0",
    "vue": "^3.4.0",
    "ws": "^8.21.0"
  }
}
